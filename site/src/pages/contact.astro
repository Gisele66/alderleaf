---
import { withBase } from '../utils/path'
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Contact Us â€” Alderleaf"
  description="Contact Alderleaf â€” 1-250-557-TREE (8733), 250-858-0525 (cell), office@alderleaf.ca, Port Clements, Haida Gwaii."
  activePage="contact"
>
  <section class="bg-cream py-20 lg:py-32">
    <div class="site-container">
      <h1 class="text-4xl font-normal sm:text-5xl lg:text-6xl">How can we help you?</h1>
      <div class="section-divider mt-5"></div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="site-container">
      <div class="grid gap-12 lg:grid-cols-[2fr_3fr] lg:gap-20">
      <div class="space-y-8">
        <div>
          <h2 class="text-2xl font-bold">Call us</h2>
          <p class="mt-2 text-lg"><a href="tel:12505578733" class="font-semibold text-forest hover:text-forest-dark">1-250-557-TREE (8733)</a></p>
          <p class="mt-1 text-lg"><a href="tel:12508580525" class="font-semibold text-forest hover:text-forest-dark">250-858-0525 (Cell)</a></p>
        </div>
        <div>
          <h2 class="text-2xl font-bold">Email Us</h2>
          <p class="mt-2 text-lg"><a href="mailto:office@alderleaf.ca" class="font-semibold text-forest hover:text-forest-dark">office@alderleaf.ca</a></p>
        </div>
        <div>
          <h2 class="text-2xl font-bold">Office Hours</h2>
          <p class="mt-3 leading-relaxed">We would love to hear from you! We are a small business with limited office staff; however, we will get back to you as soon as we are able, usually within a few business days.</p>
        </div>
        <div class="rounded-2xl bg-forest p-8 text-white">
          <h2 class="font-serif text-xl font-bold text-white">Making Payments</h2>
          <ul class="mt-4 space-y-3 text-white/90">
            <li>E-transfer to <a href="mailto:chris@alderleaf.ca" class="underline hover:text-white">chris@alderleaf.ca</a></li>
            <li>Cheques can be mailed to:<br />P.O. Box 163, Port Clements, B.C., V0T 1R0</li>
          </ul>
        </div>
        <a href={withBase('/quote')} class="inline-flex rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-white transition hover:bg-accent/90">Request a Free Quote</a>
      </div>
      <img src={withBase('/images/20220709_090309.jpg')} alt="Alderleaf on Haida Gwaii" class="w-full rounded-2xl object-cover shadow-xl lg:min-h-[32rem]" width="1200" height="1600" loading="lazy" />
      </div>
    </div>
  </section>
</BaseLayout>
