---
import { withBase } from '../utils/path'
import BaseLayout from '../layouts/BaseLayout.astro'
import PageHero from '../components/PageHero.astro'
---

<BaseLayout
  title="Services â€” Alderleaf"
  description="Alderleaf services â€” tree removal, land clearing, pruning, wood chipping, lawn care, and property maintenance on Haida Gwaii."
  activePage="services"
  heroImage="/images/20240430_162038.jpg"
>
  <PageHero image="/images/20240430_162038.jpg">
    <p class="hero-eyebrow">Haida Gwaii, BC</p>
    <h1 class="hero-heading mt-3">Services</h1>
    <p class="hero-lead">Professional land and tree services for residential and commercial properties across Haida Gwaii.</p>
  </PageHero>

  <section class="py-16 lg:py-24">
    <div class="site-container">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <a href={withBase('/removal')} class="group overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition hover:shadow-lg">
          <img src={withBase('/images/Land-Clearing.jpg')} alt="Tree removal" class="h-52 w-full object-cover transition group-hover:scale-[1.02] lg:h-64" loading="lazy" />
          <div class="p-6 lg:p-8"><h2 class="text-xl font-bold">Tree Removal</h2><p class="mt-2 text-slate">Safe take-down and removal in limited spaces.</p></div>
        </a>
        <a href={withBase('/brushing-land-clearing')} class="group overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition hover:shadow-lg">
          <img src={withBase('/images/20240430_162038.jpg')} alt="Land clearing" class="h-52 w-full object-cover transition group-hover:scale-[1.02] lg:h-64" loading="lazy" />
          <div class="p-6 lg:p-8"><h2 class="text-xl font-bold">Brushing / Land Clearing</h2><p class="mt-2 text-slate">Residential and commercial clearing projects.</p></div>
        </a>
        <a href={withBase('/pruning')} class="group overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition hover:shadow-lg">
          <img src={withBase('/images/Tree-Removal-2.jpg')} alt="Tree pruning" class="h-52 w-full object-cover transition group-hover:scale-[1.02] lg:h-64" loading="lazy" />
          <div class="p-6 lg:p-8"><h2 class="text-xl font-bold">Tree Pruning and Shrub Trimming</h2><p class="mt-2 text-slate">Hedges, shrubs, and ornamental pruning.</p></div>
        </a>
        <a href={withBase('/chips')} class="group overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition hover:shadow-lg">
          <img src={withBase('/images/Woodchipping.jpg')} alt="Wood chipping" class="h-52 w-full object-cover transition group-hover:scale-[1.02] lg:h-64" loading="lazy" />
          <div class="p-6 lg:p-8"><h2 class="text-xl font-bold">Firewood, Wood-Chipping &amp; Mulch</h2><p class="mt-2 text-slate">Chipping services and mulch delivery.</p></div>
        </a>
        <a href={withBase('/lawn-care')} class="group overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition hover:shadow-lg">
          <img src={withBase('/images/Lawn-Care.jpg')} alt="Lawn care" class="h-52 w-full object-cover transition group-hover:scale-[1.02] lg:h-64" loading="lazy" />
          <div class="p-6 lg:p-8"><h2 class="text-xl font-bold">Lawn Care</h2><p class="mt-2 text-slate">Bi-weekly mowing and yard clean-ups.</p></div>
        </a>
        <a href={withBase('/property-maintenance')} class="group overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition hover:shadow-lg">
          <img src={withBase('/images/Property-maintenance2.jpg')} alt="Property maintenance" class="h-52 w-full object-cover transition group-hover:scale-[1.02] lg:h-64" loading="lazy" />
          <div class="p-6 lg:p-8"><h2 class="text-xl font-bold">Property Maintenance</h2><p class="mt-2 text-slate">Ongoing landscape and property care.</p></div>
        </a>
      </div>
      <div class="mt-12 text-center">
        <a href={withBase('/quote')} class="inline-flex rounded-lg bg-forest px-6 py-3 text-sm font-semibold text-white transition hover:bg-forest-dark">Request a Free Quote</a>
      </div>
    </div>
  </section>
</BaseLayout>
