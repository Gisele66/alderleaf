        <img src={withBase('/images/20220424_102637.jpg')} alt="Brushing work" class="rounded-xl object-cover shadow-md" loading="lazy" />
        <img src={withBase('/images/IMG_1955.jpg')} alt="Clearing equipment" class="rounded-xl object-cover shadow-md" loading="lazy" />
        <img src={withBase('/images/20220424_102807.jpg')} alt="Land development clearing" class="rounded-xl object-cover shadow-md" loading="lazy" />
        <img src={withBase('/images/tree_removal-1.jpg')} alt="Tree and brush removal" class="col-span-2 rounded-xl object-cover shadow-md md:col-span-1" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="bg-forest-dark py-16 text-white lg:py-20">
