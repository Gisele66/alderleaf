---
import { withBase } from '../utils/path'

const { image, imageClass = '', containerClass = '' } = Astro.props
const imageSrc = image.startsWith('http') ? image : withBase(image)
---

<section class="page-hero relative overflow-hidden">
  <img
    src={imageSrc}
    alt=""
    class:list={['absolute inset-0 h-full w-full object-cover', imageClass]}
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <div class="hero-overlay absolute inset-0"></div>
  <div class:list={['site-container', 'page-hero-content', 'relative', 'z-[2]', containerClass]}>
    <slot />
  </div>
</section>
