---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import SiteScripts from '../components/SiteScripts.astro'
import { withBase } from '../utils/path'
import type { PageId } from '../data/nav'

interface Props {
  title: string
  description: string
  activePage: PageId
  heroImage?: string
}

const { title, description, activePage, heroImage } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href={withBase('/images/favicon-1.png')} type="image/png" />
    <link rel="preload" as="image" href={withBase('/images/Color-logo-no-background.png')} />
    {heroImage && <link rel="preload" as="image" href={withBase(heroImage)} fetchpriority="high" />}
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="bg-white antialiased">
    <Header activePage={activePage} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <SiteScripts />
  </body>
</html>
